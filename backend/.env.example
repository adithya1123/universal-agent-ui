# Databricks — Service Principal OAuth (recommended)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Databricks — PAT (fallback)
# DATABRICKS_TOKEN=dapi_your_token_here

# Databricks — CLI auth (local dev fallback)
# DATABRICKS_CONFIG_PROFILE=DEFAULT

# Lakebase (provisioned instance)
LAKEBASE_INSTANCE_NAME=
LAKEBASE_URL=postgresql://user:password@host:5432/database

# Or Lakebase (autoscaling)
LAKEBASE_AUTOSCALING_PROJECT=
LAKEBASE_AUTOSCALING_BRANCH=

# MLflow
MLFLOW_EXPERIMENT_ID=
